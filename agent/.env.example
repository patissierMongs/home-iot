# InfluxDB
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=homeiot-super-secret-token
INFLUX_ORG=home
INFLUX_BUCKET=home-iot

# Agent behavior
LOG_LEVEL=INFO
