# Home Assistant
HA_URL=http://localhost:8123
HA_TOKEN=paste-long-lived-token-here

# MQTT
MQTT_HOST=localhost
MQTT_PORT=1883

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MAIN_MODEL=nemotron-cascade-2
